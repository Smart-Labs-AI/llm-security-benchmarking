# OpenAI-compatible API (e.g. OpenRouter)
OAI_BASE_URL=https://openrouter.ai/api/v1
OAI_API_KEY=sk-or-...
MAX_CONCURRENT_REQUESTS=8

# Scaleway IAM API Key
# Create one in: Scaleway Console → IAM → API Keys
# Required policy: ObjectStorageFullAccess
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXX
SCW_SECRET_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: override defaults
# S3_BUCKET=leaderboard
# S3_KEY=leaderboard.json
